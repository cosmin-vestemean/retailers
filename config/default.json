{
  "host": "localhost",
  "port": 5000,
  "public": "./public/",
  "origins": [
    "https://www.retailers.acct.ro"
  ],
  "paginate": {
    "default": 100,
    "max": 500
  },
  "mssql": {
    "client": "mssql",
    "connection": {
      "server": "127.0.0.1",
      "user": "app_retailers",
      "password": "",
      "database": "PetFactory",
      "options": {
        "encrypt": true,
        "trustServerCertificate": false
      }
    },
    "pool": {
      "min": 2,
      "max": 10,
      "idleTimeoutMillis": 30000
    }
  }
}